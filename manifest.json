{
  "name": "Obor Auto Fill Extension",
  "description": "Browser extension that auto-fills the fields for booking a volley court",
  "version": "1.0.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html",
    "default_icon": "img/icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/scripts/content.js"]
    }
  ],
  "permissions": ["tabs"]
}